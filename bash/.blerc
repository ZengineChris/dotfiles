# ~/.blerc
# Blesh configuration for Catppuccin Mocha theme

# ============================================================================
# General Settings
# ============================================================================

bleopt highlight_syntax=1
bleopt highlight_filename=1

bleopt complete_auto_complete=1
bleopt complete_auto_delay=0
bleopt complete_ambiguous=1

bleopt edit_abell=
bleopt edit_vbell=

# ============================================================================
# Catppuccin Mocha Color Theme
# ============================================================================
# Catppuccin Mocha palette:
# Rosewater: #f5e0dc, Flamingo: #f2cdcd, Pink: #f5c2e7, Mauve: #cba6f7
# Red: #f38ba8, Maroon: #eba0ac, Peach: #fab387, Yellow: #f9e2af
# Green: #a6e3a1, Teal: #94e2d5, Sky: #89dceb, Sapphire: #74c7ec
# Blue: #89b4fa, Lavender: #b4befe
# Text: #cdd6f4, Subtext1: #bac2de, Subtext0: #a6adc8
# Overlay2: #9399b2, Overlay1: #7f849c, Overlay0: #6c7086
# Surface2: #585b70, Surface1: #45475a, Surface0: #313244
# Base: #1e1e2e, Mantle: #181825, Crust: #11111b

# Editing
ble-face -s region bg=#45475a
ble-face -s region_target bg=#585b70
ble-face -s region_match bg=#313244,fg=#a6e3a1
ble-face -s region_insert fg=#89b4fa,bg=#1e1e2e
ble-face -s disabled fg=#7f849c
ble-face -s overwrite_mode fg=#11111b,bg=#74c7ec
ble-face -s vbell reverse
ble-face -s vbell_erase bg=#313244
ble-face -s vbell_flash fg=#a6e3a1,reverse
ble-face -s prompt_status_line fg=#cdd6f4,bg=#313244

# Syntax highlighting
ble-face -s syntax_default fg=#cdd6f4
ble-face -s syntax_command fg=#89b4fa
ble-face -s syntax_quoted fg=#a6e3a1
ble-face -s syntax_quotation fg=#a6e3a1,bold
ble-face -s syntax_escape fg=#f5c2e7
ble-face -s syntax_expr fg=#fab387
ble-face -s syntax_error bg=#f38ba8,fg=#11111b
ble-face -s syntax_varname fg=#f5c2e7
ble-face -s syntax_delimiter fg=#cdd6f4
ble-face -s syntax_param_expansion fg=#f5c2e7
ble-face -s syntax_history_expansion bg=#fab387,fg=#11111b
ble-face -s syntax_function_name fg=#89b4fa,bold
ble-face -s syntax_comment fg=#6c7086
ble-face -s syntax_glob fg=#fab387,bold
ble-face -s syntax_brace fg=#fab387
ble-face -s syntax_tilde fg=#94e2d5
ble-face -s syntax_document fg=#a6e3a1
ble-face -s syntax_document_begin fg=#a6e3a1,bold

# Command types
ble-face -s command_builtin fg=#f9e2af
ble-face -s command_builtin_dot fg=#f9e2af
ble-face -s command_alias fg=#cba6f7
ble-face -s command_function fg=#89b4fa
ble-face -s command_file fg=#89b4fa
ble-face -s command_keyword fg=#cba6f7
ble-face -s command_directory fg=#89b4fa,bold
ble-face -s command_jobs fg=#94e2d5
ble-face -s command_suffix fg=#a6e3a1

# Variables
ble-face -s varname_array fg=#f5c2e7
ble-face -s varname_empty fg=#7f849c
ble-face -s varname_export fg=#fab387
ble-face -s varname_expr fg=#f5c2e7
ble-face -s varname_hash fg=#cba6f7
ble-face -s varname_number fg=#fab387
ble-face -s varname_readonly fg=#f38ba8
ble-face -s varname_transform fg=#89dceb
ble-face -s varname_unset fg=#6c7086

# Arguments
ble-face -s argument_option fg=#f2cdcd
ble-face -s argument_error bg=#f38ba8,fg=#11111b

# Filenames
ble-face -s filename_directory fg=#89b4fa,bold
ble-face -s filename_directory_sticky fg=#11111b,bg=#a6e3a1
ble-face -s filename_link fg=#94e2d5
ble-face -s filename_orphan fg=#f38ba8,bold
ble-face -s filename_executable fg=#a6e3a1
ble-face -s filename_setuid fg=#f38ba8,bold
ble-face -s filename_setgid fg=#fab387,bold
ble-face -s filename_other fg=#cdd6f4
ble-face -s filename_socket fg=#f5c2e7
ble-face -s filename_pipe fg=#f9e2af
ble-face -s filename_character fg=#fab387
ble-face -s filename_block fg=#f9e2af
ble-face -s filename_warning fg=#f38ba8
ble-face -s filename_url fg=#74c7ec,underline
ble-face -s filename_ls_colors none

# Auto-complete
ble-face -s auto_complete fg=#6c7086

# Completion menu
ble-face -s menu_filter_fixed fg=#a6e3a1,bold
ble-face -s menu_filter_input fg=#f9e2af,underline
ble-face -s menu_desc_default fg=#bac2de
ble-face -s menu_desc_type fg=#94e2d5
ble-face -s menu_desc_quote fg=#a6e3a1

# Misc
ble-face -s cmdinfo_cd_cdpath fg=#89b4fa,bg=#11111b
bleopt filename_ls_colors="di=34:ln=36:ex=32"
